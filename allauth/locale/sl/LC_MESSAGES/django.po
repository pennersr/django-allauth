#: mfa/adapter.py:30
msgid ""
"You cannot add an email address to an account protected by two-factor "
"authentication."
msgstr ""
"Ne morete dodati e-poštnega naslova računu, zaščitenem z dvostopenjsko "
"avtentikacijo."

#: mfa/adapter.py:33
msgid "You cannot deactivate two-factor authentication."
msgstr "Ne morete deaktivirati dvostopenjske avtentikacije."

#: mfa/adapter.py:36
msgid ""
